{
    "version": 2,
    "builds": [
        {
            "src": "api/clip.js",
            "use": "@vercel/node"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/clip",
            "dest": "api/clip.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}